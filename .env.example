# =============================================================================
# THE CORE AGENCY / CLAUDE_MARKETING_TEAM — Environment Variables
# Connector-ready placeholder documentation (no real secrets)
#
# INSTRUCTIONS:
#   1. Copy this file to .env.local (NOT .env)
#   2. Fill in real values from the relevant provider dashboards
#   3. NEVER commit .env.local or any file with real secrets
#   4. .env.local is already in .gitignore
#
# RULES:
#   - Do not hardcode any value from this file in source code.
#   - Real AI/connector keys live ONLY in n8n Credentials, Vercel env, Supabase
#     env, or a local .env that is never committed.
#   - Anything VITE_-prefixed is exposed to the browser bundle — put ONLY
#     non-secret, public-safe values there (URLs/anon keys/app identity).
#   - Connectors are OFF by default and approval-gated. See:
#     CLAUDE_MARKETING_TEAM/07_runbooks/connector_activation_safety_runbook.md
# =============================================================================


# --------------------------------------------------------
# CORE APP (public, safe to expose in the browser bundle)
# --------------------------------------------------------
VITE_APP_URL=
VITE_APP_NAME=The Core Agency
VITE_APP_TAGLINE=AI Marketing Team Workspace
VITE_APP_MODE=Real Operations MVP


# --------------------------------------------------------
# SUPABASE
# Get from: Supabase Dashboard → Settings → API
# --------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side only (NOT prefixed with VITE_ — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=do_not_commit_real_secret

# Get from: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres


# --------------------------------------------------------
# n8n — automation runtime / AI-provider router
# Webhook URLs are read by the browser (VITE_-prefixed). Leave blank to use the
# local fallback generator. The real webhook URLs and any AI provider keys must
# stay in n8n Credentials — never commit a real URL/secret.
#
# Each module produces DRAFTS/SPECS only and lands in the approval queue:
#   - Content Factory  — no auto-post
#   - Design Factory   — no real image generation
#   - Video Scripts    — no real video generation
#   - Ads Pack Draft   — no ad creation/launch/spend, not wired to any ad account
#   - Report Draft     — no live analytics pull, no unverified metrics
# --------------------------------------------------------
VITE_N8N_CONTENT_FACTORY_WEBHOOK_URL=
VITE_N8N_DESIGN_FACTORY_WEBHOOK_URL=
VITE_N8N_VIDEO_SCRIPTS_WEBHOOK_URL=
VITE_N8N_ADS_PACK_WEBHOOK_URL=
VITE_N8N_REPORT_DRAFT_WEBHOOK_URL=

# n8n control plane (server-side only — never VITE_-prefixed)
N8N_WEBHOOK_BASE_URL=
N8N_API_KEY=do_not_commit_real_secret

# Shared secret used to sign/verify Core <-> n8n webhook callbacks.
# Generate a strong random secret: openssl rand -hex 32
# (This is the canonical webhook signing secret for this project.)
WEBHOOK_SHARED_SECRET=do_not_commit_real_secret


# --------------------------------------------------------
# AI PROVIDERS (server-side only — keys must NOT be VITE_-prefixed)
# Prefer keeping these in n8n Credentials. Listed here for documentation only.
# Get from: console.anthropic.com / platform.openai.com / aistudio.google.com
# --------------------------------------------------------
OPENAI_API_KEY=do_not_commit_real_secret
ANTHROPIC_API_KEY=do_not_commit_real_secret
GOOGLE_GEMINI_API_KEY=do_not_commit_real_secret


# --------------------------------------------------------
# DESIGN / ASSET PROVIDERS — future, approval-gated
# CURRENT PHASE: Canva runs SANDBOX / MOCK only (canvaSandboxConnector.ts) —
#   these keys are NOT required, NOT read, and NOT used. No Canva API call, no
#   design created, nothing published, real connector action = none.
# FUTURE (only after the connector activation runbook + Owner sign-off): a real
#   Canva connector could create a draft/design from a template; EXPORT only
#   happens after Owner approval AND only if ALLOW_CANVA_EXPORT_AFTER_APPROVAL=true.
# All keys server-side only / in n8n Credentials. Leave blank — never commit a real value.
# --------------------------------------------------------
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=
CANVA_BRAND_TEMPLATE_ID=
FAL_API_KEY=
IMGBB_API_KEY=
CLOUDINARY_URL=


# --------------------------------------------------------
# PUBLISHING / ADS CONNECTORS — future, approval-gated
# These remain DISCONNECTED until a per-connector Owner sign-off and the staged
# activation runbook are completed. Core never auto-posts, auto-launches ads,
# or spends. Drafts/recommendations only until an explicit human launch step.
# All keys server-side only / in n8n Credentials.
# --------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ADVERTISER_ID=
ZALO_APP_ID=
ZALO_APP_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=


# --------------------------------------------------------
# SAFETY / FEATURE FLAGS
# Defaults below are the SAFE defaults. Do not flip any flag to an unsafe value
# without explicit Owner approval and the connector activation runbook.
# --------------------------------------------------------
CONNECTORS_ENABLED=false
CONNECTOR_DRY_RUN=true
REQUIRE_OWNER_APPROVAL=true
ALLOW_AUTO_POST=false
ALLOW_AUTO_ADS_LAUNCH=false
ALLOW_CANVA_EXPORT_AFTER_APPROVAL=false
